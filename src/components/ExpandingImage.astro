---
interface Props {
  href?: string;
  label?: string;
}

const {
  href = '/notes/yishui-spring-breeze/',
  label = '进入沂水春风札记页',
} = Astro.props;
---

<section class="expanding-art-section" aria-label={label}>
  <div class="expanding-art-wrap">
    <a class="expanding-art" id="expandingArt" href={href} aria-label={label}></a>
  </div>
</section>
