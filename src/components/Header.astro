---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  brand?: string;
  brandHref?: string;
  brandLabel?: string;
  nav?: NavItem[];
  languageHref?: string;
  languageLabel?: string;
  languageAriaLabel?: string;
}

const {
  brand = '舞雩台',
  brandHref = '/',
  brandLabel = '舞雩台首页',
  nav = [
    { href: '/archive/', label: '档案' },
    { href: '#works', label: '作品' },
    { href: '#notes', label: '札记' },
    { href: '#now', label: '近况' },
  ],
  languageHref,
  languageLabel,
  languageAriaLabel = 'Switch language',
} = Astro.props;
---

<header class="site-header">
  <a class="brand" href={brandHref} aria-label={brandLabel}>{brand}</a>
  <div class="header-actions">
    <nav class="nav" aria-label="Primary navigation">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    {
      languageHref && languageLabel && (
        <a class="language-switch" href={languageHref} aria-label={languageAriaLabel}>
          {languageLabel}
        </a>
      )
    }
  </div>
</header>
