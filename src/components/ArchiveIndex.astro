---
import WorkCard from './WorkCard.astro';

const works = [
  {
    index: '01',
    title: '乌鸦的游记',
    text: '从一个死去流浪者的口袋里，你能翻到什么......',
    href: '/works/crow-travelogue/',
  },
  {
    index: '02',
    title: '三国的第二次落幕',
    text: '一次在公元280年，一次在童年结束的时候。',
    href: '/works/three-kingdoms-fall/',
  },
  {
    index: '03',
    title: '世界是草台班子',
    text: '现实像一座不断打补丁的旧建筑。',
    href: '/works/cardboard-world/',
  },
];
---

<section class="works" id="works">
  <div class="section-head">
    <p class="eyebrow">Selected fragments</p>
    <h2>一些正在形成的东西</h2>
  </div>

  <div class="work-grid">
    {works.map((work) => <WorkCard {...work} />)}
  </div>
</section>

<section class="now" id="now">
  <div>
    <p class="eyebrow">Now</p>
    <h2>最近在想</h2>
  </div>
  <ul>
    <li>如何把个人主页做成一间安静的档案馆。</li>
    <li>AI 公司从挑战者变成权力本身时，人为什么会失落。</li>
    <li>那些没有写完的故事，是否也有保存的价值。</li>
  </ul>
</section>

<section class="notes-band" id="notes">
  <p class="eyebrow">Notes</p>
  <a href="/notes/making-an-archive/">
    <span>一则开馆札记</span>
    <strong>把个人主页做成一间安静的档案馆</strong>
  </a>
</section>
