---
import ArchiveIndex from '../components/ArchiveIndex.astro';
import ExpandingImage from '../components/ExpandingImage.astro';
import Header from '../components/Header.astro';
import TypingHero from '../components/TypingHero.astro';
import ArchiveLayout from '../layouts/ArchiveLayout.astro';
---

<ArchiveLayout title="舞雩台 | Rain Altar Archive">
  <Header />
  <main>
    <TypingHero />
    <ExpandingImage />
    <ArchiveIndex />
  </main>
  <footer class="footer" id="about">
    <p>A small archive for unfinished thoughts.</p>
    <p>Built with Astro and Starlight.</p>
  </footer>
  <script is:inline src="/scripts/home.js"></script>
</ArchiveLayout>
